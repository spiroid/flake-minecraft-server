{
	// Allows poly lib to run as a server side only support. Without this, non-vanilla clients without polylib may not be able to connect.
	"serverOnlySupport": true,
	// When true, all registered accessibility preferences treat the player's value as authoritative, ignoring server policy.
	"radicalAccessibility": false,
	// Controls whether the keyboard shortcut for each registered config panel is enabled. Keys are mod IDs.
	"configPanelKeybinds": { }
}