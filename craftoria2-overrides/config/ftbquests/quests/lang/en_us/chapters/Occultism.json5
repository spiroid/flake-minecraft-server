  "task.7E36340AFD8F91C6.title": "Summon a Greedy Familiar",
  "quest.209744C68891F1DA.quest_desc": [
    "The Bat allows you to &6see&r in the &bdark&r.",
  ],
  "quest.00AC0C951A5D79D9.quest_subtitle": "Perfect Foundation",
  "quest.6F9513334361D44E.quest_desc": [
